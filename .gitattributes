# Force LF line endings for all text files in this repo
# regardless of OS or git.autocrlf setting
* text=auto eol=lf

# Explicitly LF for web/code files
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.sh      text eol=lf
*.ps1     text eol=lf
*.bat     text eol=lf
*.txt     text eol=lf
*.gitignore text eol=lf

# Binary files — no conversion
*.png     binary
*.jpg     binary
*.ico     binary
*.woff2   binary
*.woff    binary
